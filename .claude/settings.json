{
  "permissions": {
    "allow": [
      "Bash(npm run test:run)",
      "Bash(npm run test:e2e)",
      "Bash(git -C * diff *)",
      "Bash(git -C * status)",
      "Bash(git -C * log *)",
      "Bash(npx tsc --noEmit)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/ci-guard.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
